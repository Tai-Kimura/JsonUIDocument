{
  "type": "screen_spec",
  "version": "1.0",
  "metadata": {
    "name": "TestRunner",
    "displayName": "jsonui-test-runner",
    "description": "Tools > test runner overview. JSON-authored tests driving real apps across iOS / Android / Web. Four sections: JSON test file shape / Lookup + interact + assert DSL / Per-platform drivers / CI integration. ~8-min read.",
    "platforms": [
      "web"
    ],
    "layoutFile": "tools/test-runner",
    "createdAt": "2026-04-23",
    "updatedAt": "2026-04-23"
  },
  "structure": {
    "components": [],
    "layout": {},
    "collection": null,
    "tabView": null
  },
  "stateManagement": {
    "states": [],
    "uiVariables": [
      {
        "name": "nextReadLinks",
        "type": "[NextReadLink]",
        "initial": "[]",
        "description": "Two closing cards."
      }
    ],
    "eventHandlers": [
      {
        "name": "onAppear",
        "description": "Seed nextReadLinks."
      },
      {
        "name": "onNavigate",
        "params": [
          {
            "name": "url",
            "type": "String"
          }
        ],
        "description": "Client-side navigation."
      }
    ],
    "displayLogic": []
  },
  "dataFlow": {
    "diagram": "flowchart TD\n    VIEW --> VM",
    "viewModel": {
      "methods": [
        {
          "name": "onAppear",
          "description": "Seed nextReadLinks from the module-scope NEXT_READ_ENTRIES catalog (two rows: next_cli -> /tools/cli, next_testing_guide -> /guides/testing) and stamp currentLanguage from StringManager.language. Each row's titleKey / descriptionKey is resolved through StringManager with the tools_test_runner_ namespace prefix."
        },
        {
          "name": "onNavigate",
          "params": [
            {
              "name": "url",
              "type": "String"
            }
          ],
          "description": "Client-side navigation via router.push(url). Destinations are the spec-mapped URLs enumerated in transitions: /, /guides/testing, /tools/cli."
        }
      ],
      "vars": [
        {
          "name": "nextReadLinks",
          "type": "Array(NextReadLink)",
          "observable": true,
          "description": "Two closing 'read next' cards pointing at /tools/cli and /guides/testing. Seeded by onAppear from the NEXT_READ_ENTRIES static catalog and re-seeded by onToggleLanguage."
        }
      ]
    },
    "repositories": [],
    "useCases": [],
    "apiEndpoints": [],
    "customTypes": [
      {
        "name": "NextReadLink",
        "properties": [
          {
            "name": "id",
            "type": "String"
          },
          {
            "name": "titleKey",
            "type": "String"
          },
          {
            "name": "descriptionKey",
            "type": "String"
          },
          {
            "name": "url",
            "type": "String"
          }
        ]
      }
    ]
  },
  "userActions": [
    {
      "action": "Tap a TOC entry",
      "processing": "TOC-internal scroll."
    },
    {
      "action": "Tap a NextReadLink card",
      "processing": "onNavigate(url)."
    }
  ],
  "validation": {
    "clientSide": [],
    "serverSide": []
  },
  "transitions": [
    {
      "trigger": "onNavigate(url)",
      "condition": "url is spec-mapped",
      "destination": "Target screen or tab",
      "description": "v1: /, /guides/testing (upcoming), /tools/cli."
    }
  ],
  "relatedFiles": [
