    "components": [],
    "layout": {},
    "collection": null,
    "tabView": null
  },
  "stateManagement": {
    "states": [],
    "uiVariables": [
      {
        "name": "nextReadLinks",
        "type": "[NextReadLink]",
        "initial": "[]",
        "description": "Two closing cards."
      }
    ],
    "eventHandlers": [
      {
        "name": "onAppear",
        "description": "Seed nextReadLinks."
      },
      {
        "name": "onNavigate",
        "params": [
          {
            "name": "url",
            "type": "String"
          }
        ],
