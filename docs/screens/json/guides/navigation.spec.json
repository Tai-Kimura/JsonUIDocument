    "displayLogic": []
  },
  "dataFlow": {
    "diagram": "flowchart TD\n    VIEW --> VM",
    "viewModel": {
      "methods": [
        {
          "name": "onAppear",
          "description": "Seed nextReadLinks from the module-scope NEXT_READ_ENTRIES catalog (two rows: next_spec_first -> /guides/writing-your-first-spec, next_testing -> /guides/testing) and stamp currentLanguage from StringManager.language. Each row's titleKey / descriptionKey is resolved through StringManager with the guides_navigation_ namespace prefix."
        },
        {
          "name": "onNavigate",
          "params": [
            {
              "name": "url",
              "type": "String"
            }
          ],
          "description": "Client-side navigation via router.push(url). Destinations are the spec-mapped URLs enumerated in transitions: /, /guides/writing-your-first-spec, /guides/testing."
        }
      ],
      "vars": [
        {
          "name": "nextReadLinks",
          "type": "Array(NextReadLink)",
          "observable": true,
          "description": "Two closing 'read next' cards pointing at /guides/writing-your-first-spec and /guides/testing. Seeded by onAppear from the NEXT_READ_ENTRIES static catalog and re-seeded by onToggleLanguage."
        }
      ]
    },
    "repositories": [],
    "useCases": [],
    "apiEndpoints": [],
    "customTypes": [
      {
        "name": "NextReadLink",
        "properties": [
          {
            "name": "id",
            "type": "String"
          },
          {
            "name": "titleKey",
            "type": "String"
          },
          {
            "name": "descriptionKey",
            "type": "String"
          },
          {
            "name": "url",
            "type": "String"
          }
        ]
      }
    ]
  },
  "userActions": [
    {
      "action": "Tap a TOC entry",
