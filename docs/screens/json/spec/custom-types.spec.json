      "methods": [
        { "name": "onAppear",   "description": "Seed nextReadLinks from NEXT_READ_ENTRIES." },
        { "name": "onNavigate", "params": [{ "name": "url", "type": "String" }], "description": "router.push." }
      ],
      "vars": [
        { "name": "nextReadLinks", "type": "Array(NextReadLink)", "observable": true, "description": "Closing cards." }
      ]
    },
    "repositories": [], "useCases": [], "apiEndpoints": [],
    "customTypes": [
      {
        "name": "NextReadLink",
        "properties": [
          { "name": "id",             "type": "String" },
          { "name": "titleKey",       "type": "String" },
          { "name": "descriptionKey", "type": "String" },
          { "name": "url",            "type": "String" }
        ]
      }
    ]
  },
  "userActions": [
    { "action": "Tap a NextReadLink card", "processing": "onNavigate(url)." }
  ],
  "validation": { "clientSide": [], "serverSide": [] },
  "transitions": [
