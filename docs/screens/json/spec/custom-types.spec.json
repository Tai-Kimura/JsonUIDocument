    "name": "SpecCustomTypes",
    "displayName": "Custom types",
    "description": "Pattern 4 of spec splitting — deep dive into dataFlow.customTypes. Declare shared row / entry shapes once and reference them by name across uiVariables and VM vars. Covers type syntax, cross-spec sharing via .jsonui-type-map.json, and when to reach for this vs a sub-spec or a component_spec.",
    "platforms": ["web"],
    "layoutFile": "spec/custom-types",
    "createdAt": "2026-04-24",
    "updatedAt": "2026-04-24"
  },
  "structure": {
    "components": [],
    "layout": {},
    "collection": null,
    "tabView": null
  },
  "stateManagement": {
    "states": [],
    "uiVariables": [
      { "name": "nextReadLinks", "type": "[NextReadLink]", "initial": "[]", "description": "Follow-up cards." }
    ],
    "eventHandlers": [
      { "name": "onAppear",   "description": "Seed nextReadLinks." },
      { "name": "onNavigate", "params": [{ "name": "url", "type": "String" }], "description": "Client-side navigation." }
    ],
    "displayLogic": []
  },
  "dataFlow": {
    "diagram": "flowchart TD\n    VIEW[SpecCustomTypesView] --> VM[SpecCustomTypesViewModel]\n    VM -- nextReadLinks --> VIEW",
