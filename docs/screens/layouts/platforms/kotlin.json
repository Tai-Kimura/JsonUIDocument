{
  "type": "View",
  "id": "platforms_kotlin_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "#F9FAFB",
  "child": [
    {
      "data": [
        {
          "name": "nextReadLinks",
          "class": "CollectionDataSource"
        },
        {
          "name": "onNavigatePlatforms",
          "class": "() -> Void"
        }
      ]
    },
    {
      "type": "Scroll",
      "id": "platforms_kotlin_scroll",
      "width": "matchParent",
      "weight": 1,
      "child": [
        {
          "type": "View",
          "orientation": "vertical",
          "id": "platforms_kotlin_header",
          "width": "matchParent",
          "height": "wrapContent",
          "paddings": [
            24,
            32,
            24,
            32
          ],
          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "#64748B",
              "tapBackground": "#F3F4F6",
              "onClick": "@{onNavigatePlatforms}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "#0B1220",
              "text": "title"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "#475467",
              "text": "lead"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 12,
              "fontSize": 13,
              "fontColor": "#64748B",
              "text": "read_time"
            }
          ]
        },
        {
          "type": "View",
          "id": "platforms_kotlin_content_with_rail",
          "orientation": "horizontal",
          "width": "matchParent",
          "height": "wrapContent",
          "child": [
            {
              "type": "View",
              "id": "platforms_kotlin_body_column",
              "orientation": "vertical",
              "weight": 1,
              "height": "wrapContent",
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_get",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_get_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_get_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_dual",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_dual_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_dual_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_dynamic",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_dynamic_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_dynamic_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_prod",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_prod_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_prod_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "platforms_kotlin_next",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    32,
                    32,
                    32,
                    32
                  ],
                  "background": "chrome_fill",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 24,
                      "fontWeight": "bold",
                      "fontColor": "chrome_ink",
                      "text": "next_heading"
                    },
                    {
                      "type": "Collection",
                      "id": "platforms_kotlin_next_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 2,
                      "lineSpacing": 16,
                      "itemSpacing": 16,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{nextReadLinks}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "platforms_kotlin_footer",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    32,
                    32
                  ],
                  "background": "chrome_fill",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 12,
                      "fontColor": "#94A3B8",
                      "text": "footer_copyright"
                    }
                  ]
                }
              ]
            },
            {
              "type": "View",
              "id": "platforms_kotlin_rail_column",
              "orientation": "vertical",
              "width": 260,
              "height": "wrapContent",
              "paddings": [
                24,
                16,
                24,
                16
              ],
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "platforms_kotlin_toc_wrap",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    0,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "TableOfContents",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "title": "toc_title",
                      "sticky": true,
                      "maxDepth": 1,
                      "items": [
                        {
                          "id": "toc_get",
                          "label": "toc_row_get",
                          "anchor": "section_get",
                          "level": 1
                        },
                        {
                          "id": "toc_dual",
                          "label": "toc_row_dual",
                          "anchor": "section_dual",
                          "level": 1
                        },
                        {
                          "id": "toc_dynamic",
                          "label": "toc_row_dynamic",
                          "anchor": "section_dynamic",
                          "level": 1
                        },
                        {
                          "id": "toc_prod",
                          "label": "toc_row_prod",
                          "anchor": "section_prod",
                          "level": 1
                        }
                      ],
                      "stickyOffset": 80
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
