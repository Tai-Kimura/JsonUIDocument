{
  "type": "View",
  "orientation": "horizontal",
  "width": "wrapContent",
  "height": "wrapContent",
  "leftMargin": 4,
  "paddings": [2, 8, 2, 8],
  "cornerRadius": 4,
  "background": "@{background}",
  "child": [
    {
      "data": [
        { "name": "label", "class": "String" },
        { "name": "background", "class": "String", "defaultValue": "#F3F4F6" },
        { "name": "fontColor", "class": "String", "defaultValue": "#0B1220" }
      ]
    },
    {
      "type": "Label",
      "width": "wrapContent",
      "height": "wrapContent",
      "fontSize": 11,
      "fontFamily": "monospace",
      "fontColor": "@{fontColor}",
      "text": "@{label}"
    }
  ]
}
