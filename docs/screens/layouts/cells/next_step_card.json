{
  "type": "View",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "wrapContent",
  "style": "card_surface",
  "tapBackground": "#F3F4F6",
  "onClick": "@{onNavigate}",
  "child": [
    {
      "data": [
        { "name": "titleKey", "class": "String" },
        { "name": "descriptionKey", "class": "String" },
        { "name": "url", "class": "String" },
        { "name": "onNavigate", "class": "() -> Void" }
      ]
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "fontSize": 20,
      "fontWeight": "semibold",
      "fontColor": "#0B1220",
      "text": "@{titleKey}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 8,
      "fontSize": 15,
      "fontColor": "#475467",
      "text": "@{descriptionKey}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 16,
      "fontSize": 14,
      "fontWeight": "semibold",
      "fontColor": "accent_link",
      "text": "@{url}"
    }
  ]
}
