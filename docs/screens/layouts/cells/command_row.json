{
  "type": "View",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "wrapContent",
  "paddings": [12, 16, 12, 16],
  "background": "#FFFFFF",
  "cornerRadius": 10,
  "borderWidth": 1,
  "borderColor": "#E5E7EB",
  "child": [
    {
      "data": [
        { "name": "commandKey", "class": "String" },
        { "name": "descriptionKey", "class": "String" },
        { "name": "flagsKey", "class": "String" }
      ]
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "fontSize": 14,
      "fontWeight": "bold",
      "fontColor": "#0B1220",
      "text": "@{commandKey}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 6,
      "fontSize": 14,
      "fontColor": "#475467",
      "text": "@{descriptionKey}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 6,
      "fontSize": 12,
      "fontColor": "#94A3B8",
      "text": "@{flagsKey}"
    }
  ]
}
