{
  "type": "View",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "wrapContent",
  "style": "card_surface",
  "child": [
    {
      "data": [
        { "name": "nameKey", "class": "String" },
        { "name": "roleKey", "class": "String" },
        { "name": "bodyKey", "class": "String" }
      ]
    },
    {
      "type": "View",
      "orientation": "horizontal",
      "width": "matchParent",
      "height": "wrapContent",
      "child": [
        {
          "type": "Label",
          "weight": 1,
          "height": "wrapContent",
          "fontSize": 17,
          "fontWeight": "bold",
          "fontColor": "#0B1220",
          "text": "@{nameKey}"
        },
        {
          "type": "Label",
          "width": "wrapContent",
          "height": "wrapContent",
          "paddings": [3, 10, 3, 10],
          "fontSize": 11,
          "fontWeight": "semibold",
          "fontColor": "#FFFFFF",
          "background": "#2563EB",
          "cornerRadius": 999,
          "text": "@{roleKey}"
        }
      ]
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 8,
      "fontSize": 14,
      "fontColor": "#475467",
      "text": "@{bodyKey}"
    }
  ]
}
