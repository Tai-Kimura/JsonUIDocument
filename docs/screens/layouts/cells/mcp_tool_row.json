{
  "type": "View",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "wrapContent",
  "paddings": [
    12,
    16,
    12,
    16
  ],
  "background": "#FFFFFF",
  "cornerRadius": 10,
  "borderWidth": 1,
  "borderColor": "#E5E7EB",
  "child": [
    {
      "data": [
        {
          "name": "nameKey",
          "class": "String"
        },
        {
          "name": "groupKey",
          "class": "String"
        },
        {
          "name": "roleKey",
          "class": "String"
        }
      ]
    },
    {
      "type": "View",
      "orientation": "horizontal",
      "width": "matchParent",
      "height": "wrapContent",
      "child": [
        {
          "type": "Label",
          "width": "wrapContent",
          "height": "wrapContent",
          "paddings": [
            2,
            8,
            2,
            8
          ],
          "fontSize": 11,
          "fontWeight": "bold",
          "fontColor": "pure_white",
          "background": "#1F2937",
          "cornerRadius": 6,
          "rightMargin": 8,
          "text": "@{groupKey}"
        },
        {
          "type": "Label",
          "weight": 1,
          "height": "wrapContent",
          "fontSize": 14,
          "fontWeight": "semibold",
          "fontColor": "#0B1220",
          "text": "@{nameKey}"
        }
      ]
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 4,
      "fontSize": 12,
      "fontColor": "#475467",
      "text": "@{roleKey}"
    }
