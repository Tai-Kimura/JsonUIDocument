{
  "type": "View",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "wrapContent",
  "style": "card_surface",
  "child": [
    {
      "data": [
        { "name": "titleKey", "class": "String" },
        { "name": "locationKey", "class": "String" },
        { "name": "bodyKey", "class": "String" },
        { "name": "iconName", "class": "String" }
      ]
    },
    {
      "type": "Label",
      "width": "wrapContent",
      "height": "wrapContent",
      "paddings": [4, 10, 4, 10],
      "fontSize": 12,
      "fontWeight": "semibold",
      "fontColor": "#0B1220",
      "background": "#E0E7FF",
      "cornerRadius": 999,
      "text": "@{iconName}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 12,
      "fontSize": 18,
      "fontWeight": "semibold",
      "fontColor": "#0B1220",
      "text": "@{titleKey}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 6,
      "fontSize": 13,
      "fontWeight": "semibold",
      "fontColor": "accent_link",
      "text": "@{locationKey}"
    },
    {
      "type": "Label",
      "width": "matchParent",
      "height": "wrapContent",
      "topMargin": 8,
      "fontSize": 14,
      "fontColor": "#475467",
      "text": "@{bodyKey}"
    }
  ]
}
