{
  "type": "View",
  "orientation": "horizontal",
  "width": "matchParent",
  "height": "wrapContent",
  "paddings": [10, 16, 10, 16],
  "background": "#FFFFFF",
  "cornerRadius": 10,
  "borderWidth": 1,
  "borderColor": "#E5E7EB",
  "child": [
    {
      "data": [
        { "name": "planKey", "class": "String" },
        { "name": "limitKey", "class": "String" },
        { "name": "intervalKey", "class": "String" }
      ]
    },
    {
      "type": "Label",
      "width": "wrapContent",
      "height": "wrapContent",
      "paddings": [3, 10, 3, 10],
      "fontSize": 11,
      "fontWeight": "semibold",
      "fontColor": "pure_white",
      "background": "accent_marker",
      "cornerRadius": 999,
      "rightMargin": 12,
      "text": "@{planKey}"
    },
    {
      "type": "Label",
      "weight": 1,
      "height": "wrapContent",
      "fontSize": 14,
      "fontWeight": "semibold",
      "fontColor": "#0B1220",
      "text": "@{limitKey}"
    },
    {
      "type": "Label",
      "width": "wrapContent",
      "height": "wrapContent",
      "fontSize": 13,
      "fontColor": "#475467",
      "text": "@{intervalKey}"
    }
  ]
}
