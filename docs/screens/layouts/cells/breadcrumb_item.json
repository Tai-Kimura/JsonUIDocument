{
  "type": "View",
  "orientation": "horizontal",
  "width": "wrapContent",
  "height": "wrapContent",
  "child": [
    {
      "data": [
        { "name": "labelKey", "class": "String" },
        { "name": "onNavigate", "class": "() -> Void" }
      ]
    },
    {
      "type": "Button",
      "width": "wrapContent",
      "height": "wrapContent",
      "paddings": [4, 6, 4, 0],
      "background": "#00000000",
      "fontSize": 13,
      "fontWeight": "medium",
      "fontColor": "accent_link",
      "cornerRadius": 6,
      "tapBackground": "#EFF6FF",
      "text": "@{labelKey}",
      "onClick": "@{onNavigate}"
    },
    {
      "type": "Label",
      "width": "wrapContent",
      "height": "wrapContent",
      "leftMargin": 6,
      "fontSize": 13,
      "fontColor": "#94A3B8",
      "text": "breadcrumb_separator"
    }
  ]
}
