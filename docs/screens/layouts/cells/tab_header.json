{
  "type": "Button",
  "width": "matchParent",
  "height": "wrapContent",
  "paddings": [12, 16, 12, 16],
  "background": "#FFFFFF",
  "fontSize": 15,
  "fontWeight": "semibold",
  "fontColor": "#0B1220",
  "cornerRadius": 10,
  "borderWidth": 1,
  "borderColor": "#E5E7EB",
  "tapBackground": "#EFF6FF",
  "child": [
    {
      "data": [
        { "name": "labelKey", "class": "String" },
        { "name": "onSelect", "class": "() -> Void" }
      ]
    }
  ],
  "text": "@{labelKey}",
  "onClick": "@{onSelect}"
}
