{
  "type": "View",
  "id": "tools_mcp_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "#F9FAFB",
  "child": [
    {
      "data": [
        {
          "name": "tools",
          "class": "CollectionDataSource"
        },
        {
          "name": "nextReadLinks",
          "class": "CollectionDataSource"
        },
        {
          "name": "onNavigateTools",
          "class": "() -> Void"
        }
      ]
    },
    {
      "type": "Scroll",
      "id": "tools_mcp_scroll",
      "width": "matchParent",
      "weight": 1,
      "child": [
        {
          "type": "View",
          "orientation": "vertical",
          "id": "tools_mcp_header",
          "width": "matchParent",
          "height": "wrapContent",
          "paddings": [
            24,
            32,
            24,
            32
          ],
          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "#64748B",
              "tapBackground": "#F3F4F6",
              "onClick": "@{onNavigateTools}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "#0B1220",
              "text": "title"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "#475467",
              "text": "lead"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 12,
              "fontSize": 13,
              "fontColor": "#64748B",
              "text": "read_time"
            }
          ]
        },
        {
          "type": "View",
          "id": "tools_mcp_content_with_rail",
          "orientation": "horizontal",
          "width": "matchParent",
          "height": "wrapContent",
          "child": [
            {
              "type": "View",
              "id": "tools_mcp_body_column",
              "orientation": "vertical",
              "weight": 1,
              "height": "wrapContent",
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_what",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_what_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_what_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_shape",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_shape_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_shape_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "{\n  \"tool\": \"lookup_component\",\n  \"input\": { \"name\": \"Collection\" },\n  \"output\": {\n    \"name\": \"Collection\",\n    \"platforms\": [\"ios\", \"android\", \"web\"],\n    \"attributes\": [\n      { \"name\": \"items\",          \"type\": [\"CollectionDataSource\", \"binding\"], \"required\": true },\n      { \"name\": \"cellIdProperty\", \"type\": \"String\" },\n      { \"name\": \"sections\",       \"type\": \"[CollectionSection]\" }\n    ]\n  }\n}",
                      "language": "json",
                      "filename": "lookup_component (example response)",
                      "showLineNumbers": true,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_catalog",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_catalog_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_catalog_body"
                    },
                    {
                      "type": "Collection",
                      "id": "tools_mcp_catalog_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 1,
                      "lineSpacing": 10,
                      "itemSpacing": 10,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{tools}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/mcp_tool_row"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_groups",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_groups_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_groups_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "tools_mcp_next",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    32,
                    32,
                    32,
                    32
                  ],
                  "background": "chrome_fill",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 24,
                      "fontWeight": "bold",
                      "fontColor": "chrome_ink",
                      "text": "next_heading"
                    },
                    {
                      "type": "Collection",
                      "id": "tools_mcp_next_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 2,
                      "lineSpacing": 16,
                      "itemSpacing": 16,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{nextReadLinks}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "tools_mcp_footer",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    32,
                    32
                  ],
                  "background": "chrome_fill",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 12,
                      "fontColor": "#94A3B8",
                      "text": "footer_copyright"
                    }
                  ]
                }
              ]
            },
            {
              "type": "View",
              "id": "tools_mcp_rail_column",
              "orientation": "vertical",
              "width": 260,
              "height": "wrapContent",
              "paddings": [
                24,
                16,
                24,
                16
              ],
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "tools_mcp_toc_wrap",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    0,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "TableOfContents",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "title": "toc_title",
                      "sticky": true,
                      "maxDepth": 1,
                      "items": [
                        {
                          "id": "toc_what",
                          "label": "toc_row_what",
                          "anchor": "section_what",
                          "level": 1
                        },
                        {
                          "id": "toc_shape",
                          "label": "toc_row_shape",
                          "anchor": "section_shape",
                          "level": 1
                        },
                        {
                          "id": "toc_catalog",
                          "label": "toc_row_catalog",
                          "anchor": "section_catalog",
                          "level": 1
                        },
                        {
                          "id": "toc_groups",
                          "label": "toc_row_groups",
                          "anchor": "section_groups",
                          "level": 1
                        }
                      ],
                      "stickyOffset": 80
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
