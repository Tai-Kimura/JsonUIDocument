{
  "type": "View",
  "id": "tools_test_runner_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "#F9FAFB",
  "child": [
    {
      "data": [
        {
          "name": "nextReadLinks",
          "class": "CollectionDataSource"
        },
        {
          "name": "onNavigateTools",
          "class": "() -> Void"
        }
      ]
    },
    {
      "type": "Scroll",
      "id": "tools_test_runner_scroll",
      "width": "matchParent",
      "weight": 1,
      "child": [
        {
          "type": "View",
          "orientation": "vertical",
          "id": "tools_test_runner_header",
          "width": "matchParent",
          "height": "wrapContent",
          "paddings": [
            24,
            32,
            24,
            32
          ],
          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "#64748B",
              "tapBackground": "#F3F4F6",
              "onClick": "@{onNavigateTools}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "#0B1220",
              "text": "title"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "#475467",
              "text": "lead"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 12,
              "fontSize": 13,
              "fontColor": "#64748B",
              "text": "read_time"
            }
          ]
        },
        {
          "type": "View",
          "id": "tools_test_runner_content_with_rail",
          "orientation": "horizontal",
          "width": "matchParent",
          "height": "wrapContent",
          "child": [
            {
              "type": "View",
              "id": "tools_test_runner_body_column",
              "orientation": "vertical",
              "weight": 1,
              "height": "wrapContent",
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_shape",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_shape_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_shape_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "{\n  \"screen\": \"learn/installation\",\n  \"cases\": [\n    {\n      \"name\": \"renders_hero\",\n      \"description\": \"Install page hero shows the one-liner.\",\n      \"steps\": [\n        { \"assert\": \"visible\", \"id\": \"learn_installation_title\" },\n        { \"assert\": \"contains\", \"id\": \"learn_installation_cta_wrap\", \"text\": \"curl -fsSL\" }\n      ]\n    }\n  ]\n}",
                      "language": "json",
                      "filename": "tests/screens/learn/installation.test.json",
                      "showLineNumbers": true,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_dsl",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_dsl_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_dsl_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_drivers",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_drivers_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_drivers_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_ci",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_ci_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_ci_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "# .github/workflows/e2e.yml excerpt\njobs:\n  web-e2e:\n    runs-on: ubuntu-latest\n    steps:\n      - uses: actions/checkout@v4\n      - run: rjui build\n      - run: npx next start &\n      - run: jsonui-test run --platform web --base http://localhost:3000",
                      "language": "yaml",
                      "filename": ".github/workflows/e2e.yml",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "tools_test_runner_next",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    32,
                    32,
                    32,
                    32
                  ],
                  "background": "chrome_fill",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 24,
                      "fontWeight": "bold",
                      "fontColor": "chrome_ink",
                      "text": "next_heading"
                    },
                    {
                      "type": "Collection",
                      "id": "tools_test_runner_next_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 2,
                      "lineSpacing": 16,
                      "itemSpacing": 16,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{nextReadLinks}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "tools_test_runner_footer",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    32,
                    32
                  ],
                  "background": "chrome_fill",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 12,
                      "fontColor": "#94A3B8",
                      "text": "footer_copyright"
                    }
                  ]
                }
              ]
            },
            {
              "type": "View",
              "id": "tools_test_runner_rail_column",
              "orientation": "vertical",
              "width": 260,
              "height": "wrapContent",
              "paddings": [
                24,
                16,
                24,
                16
              ],
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "tools_test_runner_toc_wrap",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    0,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "TableOfContents",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "title": "toc_title",
                      "sticky": true,
                      "maxDepth": 1,
                      "items": [
                        {
                          "id": "toc_shape",
                          "label": "toc_row_shape",
                          "anchor": "section_shape",
                          "level": 1
                        },
                        {
                          "id": "toc_dsl",
                          "label": "toc_row_dsl",
                          "anchor": "section_dsl",
                          "level": 1
                        },
                        {
                          "id": "toc_drivers",
                          "label": "toc_row_drivers",
                          "anchor": "section_drivers",
                          "level": 1
                        },
                        {
                          "id": "toc_ci",
                          "label": "toc_row_ci",
                          "anchor": "section_ci",
                          "level": 1
                        }
                      ],
                      "stickyOffset": 80
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
