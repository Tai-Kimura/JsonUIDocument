                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "ink",
                      "text": "section_custom_heading"
