{
  "type": "View",
  "id": "reference_components_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "surface_muted",
  "child": [
    {
      "data": [
        {
          "name": "nextReadLinks",
          "class": "CollectionDataSource"
        },
        {
          "name": "componentCatalog",
          "class": "CollectionDataSource"
        },
        {
          "name": "onNavigateReference",
          "class": "() -> Void"
        }
      ]
    },
    {
      "type": "Scroll",
      "id": "reference_components_scroll",
      "width": "matchParent",
      "weight": 1,
      "child": [
        {
          "type": "View",
          "orientation": "vertical",
          "id": "reference_components_header",
          "width": "matchParent",
          "height": "wrapContent",
          "paddings": [
            24,
            32,
            24,
            32
          ],
          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "ink_subtle",
              "tapBackground": "surface_sunken",
              "onClick": "@{onNavigateReference}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "ink",
              "text": "title"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "ink_muted",
              "text": "lead"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 12,
              "fontSize": 13,
              "fontColor": "ink_subtle",
              "text": "read_time"
            }
          ]
        },
        {
          "type": "View",
          "id": "reference_components_content_with_rail",
