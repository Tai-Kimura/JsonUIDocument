                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "ink_muted",
                      "text": "section_catalog_body"
                    },
                    {
                      "type": "Collection",
                      "id": "reference_components_catalog_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 3,
                      "lineSpacing": 12,
                      "itemSpacing": 12,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{componentCatalog}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
