                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_ship_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "# Generate Layout + ViewModel base from the spec.\njui generate project --file recent-activity.spec.json\n\n# Keep rebuilding while you fill in the details.\njui build --watch\n\n# Before you commit, prove the layout has not drifted.\njui verify --fail-on-diff\n\n# Ship it.\ngit add docs/screens/ jsonui-doc-web/src/\ngit commit -m 'feat(activity): recent activity screen'",
                      "language": "bash",
                      "filename": "shell",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
