                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_spec_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "{\n  \"metadata\": { \"name\": \"RecentActivity\", \"platforms\": [\"web\"], \"layoutFile\": \"recent-activity\" },\n  \"stateManagement\": {\n    \"uiVariables\": [\n      { \"name\": \"welcomeKey\",   \"type\": \"String\",                \"initial\": \"\\\"\\\"\" },\n      { \"name\": \"taglineKey\",   \"type\": \"String\",                \"initial\": \"\\\"\\\"\" },\n      { \"name\": \"activities\",   \"type\": \"CollectionDataSource\",   \"initial\": \"null\" },\n      { \"name\": \"emptyVisibility\", \"type\": \"String\",              \"initial\": \"\\\"gone\\\"\" }\n    ],\n    \"eventHandlers\": [\n      { \"name\": \"onAppear\" },\n      { \"name\": \"onRefresh\" },\n      { \"name\": \"onSelectActivity\", \"params\": [{ \"name\": \"id\", \"type\": \"String\" }] }\n    ],\n    \"displayLogic\": []\n  },\n  \"dataFlow\": {\n    \"customTypes\": [\n      {\n        \"name\": \"ActivityRow\",\n        \"properties\": [\n          { \"name\": \"id\",        \"type\": \"String\" },\n          { \"name\": \"titleKey\",  \"type\": \"String\" },\n          { \"name\": \"detailKey\", \"type\": \"String\" },\n          { \"name\": \"occurredAt\",\"type\": \"Date\" }\n        ]\n      }\n    ]\n  }\n}",
                      "language": "json",
                      "filename": "recent-activity.spec.json",
                      "showLineNumbers": true,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_layout",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_layout_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_layout_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "{\n  \"type\": \"View\",\n  \"orientation\": \"vertical\",\n  \"width\": \"matchParent\",\n  \"height\": \"matchParent\",\n  \"child\": [\n    { \"type\": \"View\", \"orientation\": \"horizontal\", \"paddings\": [16, 24, 16, 24], \"background\": \"#0B1220\", \"child\": [\n      { \"type\": \"Label\", \"weight\": 1, \"fontSize\": 20, \"fontWeight\": \"semibold\", \"fontColor\": \"#F9FAFB\", \"text\": \"header_title\" },\n      { \"type\": \"Button\", \"style\": \"lang_toggle_button\", \"text\": \"lang_toggle\", \"onClick\": \"@{onToggleLanguage}\" }\n    ]},\n    { \"type\": \"View\", \"style\": \"hero_section\", \"child\": [\n      { \"type\": \"Label\", \"fontSize\": 32, \"fontWeight\": \"bold\", \"fontColor\": \"#F9FAFB\", \"text\": \"@{welcomeKey}\" },\n      { \"type\": \"Label\", \"fontSize\": 15, \"fontColor\": \"#CBD5F5\", \"text\": \"@{taglineKey}\", \"topMargin\": 8 },\n      { \"type\": \"Button\", \"style\": \"primary_button\", \"text\": \"refresh\", \"onClick\": \"@{onRefresh}\", \"topMargin\": 16 }\n    ]},\n    { \"type\": \"Collection\", \"items\": \"@{activities}\", \"cellIdProperty\": \"id\",\n      \"lineSpacing\": 12, \"itemSpacing\": 12,\n      \"sections\": [ { \"cell\": \"cells/activity_row\" } ] },\n    { \"type\": \"Label\", \"visibility\": \"@{emptyVisibility}\", \"text\": \"empty_state\" }\n  ]\n}",
                      "language": "json",
                      "filename": "recent-activity.json",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_cell",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_cell_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_cell_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "{\n  \"type\": \"View\",\n  \"orientation\": \"vertical\",\n  \"style\": \"card_surface\",\n  \"child\": [\n    { \"data\": [\n      { \"name\": \"titleKey\",  \"class\": \"String\" },\n      { \"name\": \"detailKey\", \"class\": \"String\" },\n      { \"name\": \"url\",       \"class\": \"String\" },\n      { \"name\": \"onNavigate\",\"class\": \"() -> Void\" }\n    ]},\n    { \"type\": \"Label\", \"fontSize\": 16, \"fontWeight\": \"semibold\", \"fontColor\": \"#0B1220\", \"text\": \"@{titleKey}\" },\n    { \"type\": \"Label\", \"topMargin\": 4, \"fontSize\": 14, \"fontColor\": \"#475467\", \"text\": \"@{detailKey}\" }\n  ]\n}",
                      "language": "json",
                      "filename": "cells/activity_row.json",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_wire",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_wire_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_wire_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "export class RecentActivityViewModel {\n  // ... standard init boilerplate (mirror HelloWorldViewModel) ...\n\n  onAppear = () => {\n    const rows: ActivityRow[] = [\n      { id: \"a1\", titleKey: s(\"row_1_title\"), detailKey: s(\"row_1_detail\"), occurredAt: new Date() },\n      { id: \"a2\", titleKey: s(\"row_2_title\"), detailKey: s(\"row_2_detail\"), occurredAt: new Date() },\n    ];\n    this.updateData({\n      welcomeKey: s(\"welcome\"),\n      taglineKey: s(\"tagline\"),\n      activities: this.asCollection(rows),\n      emptyVisibility: rows.length === 0 ? \"visible\" : \"gone\",\n    });\n  };\n\n  onRefresh = () => this.onAppear();\n  onSelectActivity = (id: string) => this.router.push(`/activity/${id}`);\n}",
                      "language": "typescript",
                      "filename": "RecentActivityViewModel.ts (excerpt)",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
