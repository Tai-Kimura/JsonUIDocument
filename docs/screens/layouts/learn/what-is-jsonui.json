                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_pieces_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// docs/screens/layouts/greeting.json — the ONE file you write.\n{\n  \"type\": \"View\",\n  \"orientation\": \"vertical\",\n  \"gravity\": \"center\",\n  \"paddings\": [24, 24, 24, 24],\n  \"child\": [\n    { \"data\": [\n        { \"name\": \"name\",  \"class\": \"String\", \"defaultValue\": \"world\" },\n        { \"name\": \"onTap\", \"class\": \"() -> Void\" }\n    ]},\n    { \"type\": \"Label\",  \"text\": \"Hello, @{name}\", \"fontSize\": 28, \"fontWeight\": \"bold\" },\n    { \"type\": \"Button\", \"text\": \"Say hi\",        \"onClick\": \"@{onTap}\", \"topMargin\": 12 }\n  ]\n}",
                      "language": "json",
                      "filename": "greeting.json",
                      "showLineNumbers": true,
                      "copyable": true
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "code": "// iOS (SwiftUI) — generated by sjui build\nVStack(alignment: .center, spacing: 0) {\n  Text(\"Hello, \\(vm.name)\").font(.system(size: 28, weight: .bold))\n  Button(\"Say hi\") { vm.onTap() }.padding(.top, 12)\n}\n.padding(24)\n\n// Android (Compose) — generated by kjui build\nColumn(\n  modifier = Modifier.padding(24.dp),\n  horizontalAlignment = Alignment.CenterHorizontally,\n) {\n  Text(\"Hello, ${vm.name.collectAsState().value}\", fontSize = 28.sp, fontWeight = FontWeight.Bold)\n  Button(onClick = vm::onTap, modifier = Modifier.padding(top = 12.dp)) { Text(\"Say hi\") }\n}\n\n// Web (React) — generated by rjui build\n<div className=\"flex flex-col items-center p-6\">\n  <h1 className=\"text-[28px] font-bold\">Hello, {vm.name}</h1>\n  <button className=\"mt-3\" onClick={vm.onTap}>Say hi</button>\n</div>",
                      "language": "text",
                      "filename": "three native outputs",
                      "showLineNumbers": false,
                      "copyable": false
                    }
                  ]
                },
