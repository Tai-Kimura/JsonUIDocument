                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// The contract (screen_spec.json) + the content (Layout JSON) + the\n// behavior (ViewModel) — one set of sources, three platforms out.\n{\n  \"name\": \"Counter\",\n  \"uiVariables\": [{ \"name\": \"count\", \"type\": \"Int\", \"initial\": \"0\" }],\n  \"eventHandlers\": [{ \"name\": \"onIncrement\" }]\n}",
                      "language": "json",
                      "filename": "counter.spec.json (what goes in)",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_pieces",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
