                    {
                      "type": "Collection",
                      "id": "concepts_viewmodel_owned_state_next_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 2,
                      "lineSpacing": 16,
                      "itemSpacing": 16,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{nextReadLinks}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
