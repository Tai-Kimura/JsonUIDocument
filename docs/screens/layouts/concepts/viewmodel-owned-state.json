                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_usestate_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_viewmodel_owned_state_next",
                  "width": "matchParent",
                  "height": "wrapContent",
