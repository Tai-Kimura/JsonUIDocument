                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_tradeoff_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_tradeoff_body"
                    }
