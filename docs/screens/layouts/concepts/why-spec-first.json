              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "#0B1220",
              "text": "title"
            },
            {
              "type": "Label",
              "id": "concepts_why_spec_first_lead",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "#475467",
              "text": "lead"
