          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "#64748B",
              "tapBackground": "#F3F4F6",
              "onClick": "@{onNavigateConcepts}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "id": "concepts_why_spec_first_title",
              "width": "matchParent",
              "height": "wrapContent",
