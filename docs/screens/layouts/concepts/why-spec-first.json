{
  "type": "View",
  "id": "concepts_why_spec_first_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "#F9FAFB",
  "child": [
    {
      "data": [
        {
          "name": "nextReadLinks",
