                      "sticky": true,
                      "maxDepth": 1,
                      "items": [
                        {
                          "id": "toc_contract",
                          "label": "toc_row_contract",
                          "anchor": "section_contract",
                          "level": 1
                        },
                        {
                          "id": "toc_drift",
                          "label": "toc_row_drift",
                          "anchor": "section_drift_gate",
                          "level": 1
                        },
                        {
                          "id": "toc_agent",
                          "label": "toc_row_agent",
                          "anchor": "section_agent",
                          "level": 1
                        },
                        {
                          "id": "toc_tradeoff",
                          "label": "toc_row_tradeoff",
                          "anchor": "section_tradeoff",
                          "level": 1
                        }
                      ],
                      "stickyOffset": 80
                    }
                  ]
