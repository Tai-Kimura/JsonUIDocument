{
  "type": "View",
  "id": "concepts_hot_reload_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "#F9FAFB",
  "child": [
    {
      "data": [
        {
          "name": "nextReadLinks",
          "class": "CollectionDataSource"
        },
        {
          "name": "onNavigateConcepts",
          "class": "() -> Void"
        }
      ]
    },
    {
      "type": "Scroll",
      "id": "concepts_hot_reload_scroll",
      "width": "matchParent",
      "weight": 1,
      "child": [
        {
          "type": "View",
          "orientation": "vertical",
          "id": "concepts_hot_reload_header",
          "width": "matchParent",
          "height": "wrapContent",
          "paddings": [
            24,
            32,
            24,
            32
          ],
          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "#64748B",
              "tapBackground": "#F3F4F6",
              "onClick": "@{onNavigateConcepts}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "#0B1220",
              "text": "title"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "#475467",
              "text": "lead"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 12,
              "fontSize": 13,
              "fontColor": "#64748B",
              "text": "read_time"
            }
          ]
        },
        {
          "type": "View",
          "id": "concepts_hot_reload_content_with_rail",
          "orientation": "horizontal",
          "width": "matchParent",
          "height": "wrapContent",
          "child": [
            {
              "type": "View",
              "id": "concepts_hot_reload_body_column",
              "orientation": "vertical",
              "weight": 1,
              "height": "wrapContent",
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_web",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_web_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_web_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "# Terminal 1 — regenerates TSX when the JSON / spec / VM changes\nrjui build --watch\n\n# Terminal 2 — the Next.js dev server\nnpm run dev\n\n# Open http://localhost:3000 and edit docs/screens/layouts/home.json.\n# Fast Refresh re-renders the page without losing ViewModel state.",
                      "language": "bash",
                      "filename": "shell",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_ios",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_ios_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_ios_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// AppDelegate.swift — enable Dynamic mode in DEBUG\nimport SwiftJsonUI\n\n@main\nstruct MyApp: App {\n    init() {\n        #if DEBUG\n        SwiftJsonUI.enableDynamicMode(\n            layoutsDirectory: \"docs/screens/layouts\",\n            hotReloadURL: URL(string: \"ws://localhost:8080/hot\")\n        )\n        #endif\n    }\n    var body: some Scene { WindowGroup { ContentView() } }\n}",
                      "language": "swift",
                      "filename": "MyApp.swift",
                      "showLineNumbers": true,
                      "copyable": true
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "code": "# Start the hot-reload file watcher alongside Xcode.\nsjui build --watch\n\n# Expected output:\n# 👀 Watching docs/screens/layouts/...\n# 📡 Hot-reload server on ws://localhost:8080\n# ✅ Connected: 1 simulator",
                      "language": "bash",
                      "filename": "shell",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_android",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_android_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_android_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// MyApplication.kt — enable Dynamic mode in BuildConfig.DEBUG\nimport android.app.Application\nimport com.tanosys.kotlinjsonui.KotlinJsonUI\n\nclass MyApplication : Application() {\n    override fun onCreate() {\n        super.onCreate()\n        if (BuildConfig.DEBUG) {\n            KotlinJsonUI.enableDynamicMode(\n                layoutsDirectory = \"docs/screens/layouts\",\n                hotReloadUrl = \"ws://10.0.2.2:8080/hot\"\n            )\n        }\n    }\n}",
                      "language": "kotlin",
                      "filename": "MyApplication.kt",
                      "showLineNumbers": true,
                      "copyable": true
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "code": "# Start the hot-reload file watcher alongside Android Studio.\nkjui build --watch\n\n# Note: the emulator reaches host-machine localhost via 10.0.2.2.\n# Physical devices need your LAN IP: ws://192.168.x.x:8080/hot",
                      "language": "bash",
                      "filename": "shell",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_why",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_why_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_why_body"
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_hot_reload_next",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    32,
                    32,
                    32,
                    32
                  ],
                  "background": "#0B1220",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 24,
                      "fontWeight": "bold",
                      "fontColor": "#F9FAFB",
                      "text": "next_heading"
                    },
                    {
                      "type": "Collection",
                      "id": "concepts_hot_reload_next_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 2,
                      "lineSpacing": 16,
                      "itemSpacing": 16,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{nextReadLinks}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_hot_reload_footer",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    32,
                    32
                  ],
                  "background": "#0B1220",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 12,
                      "fontColor": "#94A3B8",
                      "text": "footer_copyright"
                    }
                  ]
                }
              ]
            },
            {
              "type": "View",
              "id": "concepts_hot_reload_rail_column",
              "orientation": "vertical",
              "width": 260,
              "height": "wrapContent",
              "paddings": [
                24,
                16,
                24,
                16
              ],
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_hot_reload_toc_wrap",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    0,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "TableOfContents",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "title": "toc_title",
                      "sticky": true,
                      "maxDepth": 1,
                      "items": [
                        {
                          "id": "toc_web",
                          "label": "toc_row_web",
                          "anchor": "section_web",
                          "level": 1
                        },
                        {
                          "id": "toc_ios",
                          "label": "toc_row_ios",
                          "anchor": "section_ios",
                          "level": 1
                        },
                        {
                          "id": "toc_android",
                          "label": "toc_row_android",
                          "anchor": "section_android",
                          "level": 1
                        },
                        {
                          "id": "toc_why",
                          "label": "toc_row_why",
                          "anchor": "section_why",
                          "level": 1
                        }
                      ],
                      "stickyOffset": 80
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
