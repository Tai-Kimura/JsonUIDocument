{
  "type": "View",
  "id": "concepts_data_binding_root",
  "orientation": "vertical",
  "width": "matchParent",
  "height": "matchParent",
  "background": "#F9FAFB",
  "child": [
    {
      "data": [
        {
          "name": "nextReadLinks",
          "class": "CollectionDataSource"
        },
        {
          "name": "onNavigateConcepts",
          "class": "() -> Void"
        }
      ]
    },
    {
      "type": "Scroll",
      "id": "concepts_data_binding_scroll",
      "width": "matchParent",
      "weight": 1,
      "child": [
        {
          "type": "View",
          "orientation": "vertical",
          "id": "concepts_data_binding_header",
          "width": "matchParent",
          "height": "wrapContent",
          "paddings": [
            24,
            32,
            24,
            32
          ],
          "child": [
            {
              "type": "Label",
              "height": "wrapContent",
              "fontSize": 13,
              "fontWeight": "semibold",
              "fontColor": "#64748B",
              "tapBackground": "#F3F4F6",
              "onClick": "@{onNavigateConcepts}",
              "text": "breadcrumb",
              "width": "wrapContent"
            },
            {
              "type": "Label",
              "id": "concepts_data_binding_title",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 36,
              "fontWeight": "bold",
              "fontColor": "#0B1220",
              "text": "title"
            },
            {
              "type": "Label",
              "id": "concepts_data_binding_lead",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 16,
              "fontSize": 17,
              "fontColor": "#475467",
              "text": "lead"
            },
            {
              "type": "Label",
              "width": "matchParent",
              "height": "wrapContent",
              "topMargin": 12,
              "fontSize": 13,
              "fontColor": "#64748B",
              "text": "read_time"
            }
          ]
        },
        {
          "type": "View",
          "id": "concepts_data_binding_content_with_rail",
          "orientation": "horizontal",
          "width": "matchParent",
          "height": "wrapContent",
          "child": [
            {
              "type": "View",
              "id": "concepts_data_binding_body_column",
              "orientation": "vertical",
              "weight": 1,
              "height": "wrapContent",
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_syntax",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_syntax_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_syntax_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// Binding a label to a ViewModel field\n{ \"type\": \"Label\", \"text\": \"@{userName}\" }\n\n// Binding a visibility state\n{ \"type\": \"View\", \"visibility\": \"@{panelVisibility}\" }\n\n// Binding an event handler\n{ \"type\": \"Button\", \"onClick\": \"@{onSubmit}\" }",
                      "language": "json",
                      "filename": "layout.json",
                      "showLineNumbers": true,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_typed",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_typed_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_typed_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// spec declares the contract\n{\n  \"uiVariables\": [\n    { \"name\": \"count\",       \"type\": \"Int\",    \"initial\": \"0\" },\n    { \"name\": \"username\",    \"type\": \"String\", \"initial\": \"''\" },\n    { \"name\": \"isSubmitting\",\"type\": \"Bool\",   \"initial\": \"false\" }\n  ]\n}\n\n// ✓ Types match — build passes.\n{ \"type\": \"Label\",  \"text\":       \"@{count}\" }        // Int   → Label.text (auto-cast)\n{ \"type\": \"Button\", \"enabled\":    \"@{!isSubmitting}\" } // Bool  → Button.enabled\n\n// ✗ Types mismatch — jui build fails.\n{ \"type\": \"Label\",  \"visibility\": \"@{count}\" }        // Int   → visibility expects String\n{ \"type\": \"Button\", \"text\":       \"@{isSubmitting}\" } // Bool  → Button.text expects String",
                      "language": "text",
                      "filename": "typed binding check",
                      "showLineNumbers": false,
                      "copyable": false
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_oneway",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_oneway_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_oneway_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// User types into a TextField — data flows UP through an event handler,\n// NOT through a two-way binding.\n//\n// Layout — no bidirectional magic:\n{\n  \"type\": \"TextField\",\n  \"text\": \"@{username}\",                 // VM → Layout (display)\n  \"onChange\": \"@{onUsernameChanged}\"      // Layout → VM (via method call)\n}\n\n// ViewModel — explicit setter:\nonUsernameChanged = (next: string) => {\n  this.updateData({ username: next });     // setState; no cycles, no loops.\n};",
                      "language": "text",
                      "filename": "one-way with callback",
                      "showLineNumbers": false,
                      "copyable": false
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "section_no_logic",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    24,
                    32
                  ],
                  "background": "#FFFFFF",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 26,
                      "fontWeight": "bold",
                      "fontColor": "#0B1220",
                      "text": "section_no_logic_heading"
                    },
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 12,
                      "fontSize": 16,
                      "fontColor": "#475467",
                      "text": "section_no_logic_body"
                    },
                    {
                      "type": "CodeBlock",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 16,
                      "code": "// ✗ Not allowed\n{ \"text\": \"@{count > 0 ? 'some' : 'none'}\" }\n{ \"text\": \"@{formatName(user)}\" }\n{ \"text\": \"@{user.name.toUpperCase()}\" }\n\n// ✓ Instead, derive in ViewModel\n// ViewModel:\n//   get displayCount() -> String { count > 0 ? s('some') : s('none') }\n// Layout:\n//   { \"text\": \"@{displayCount}\" }",
                      "language": "text",
                      "filename": "invalid vs valid",
                      "showLineNumbers": false,
                      "copyable": true
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_data_binding_next",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    32,
                    32,
                    32,
                    32
                  ],
                  "background": "#0B1220",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 24,
                      "fontWeight": "bold",
                      "fontColor": "#F9FAFB",
                      "text": "next_heading"
                    },
                    {
                      "type": "Collection",
                      "id": "concepts_data_binding_next_collection",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "topMargin": 20,
                      "columnCount": 2,
                      "lineSpacing": 16,
                      "itemSpacing": 16,
                      "lazy": false,
                      "scrollEnabled": false,
                      "items": "@{nextReadLinks}",
                      "cellIdProperty": "id",
                      "sections": [
                        {
                          "cell": "cells/next_step_card"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_data_binding_footer",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    32,
                    32
                  ],
                  "background": "#0B1220",
                  "child": [
                    {
                      "type": "Label",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "fontSize": 12,
                      "fontColor": "#94A3B8",
                      "text": "footer_copyright"
                    }
                  ]
                }
              ]
            },
            {
              "type": "View",
              "id": "concepts_data_binding_rail_column",
              "orientation": "vertical",
              "width": 260,
              "height": "wrapContent",
              "paddings": [
                24,
                16,
                24,
                16
              ],
              "child": [
                {
                  "type": "View",
                  "orientation": "vertical",
                  "id": "concepts_data_binding_toc_wrap",
                  "width": "matchParent",
                  "height": "wrapContent",
                  "paddings": [
                    24,
                    32,
                    0,
                    32
                  ],
                  "background": "#F9FAFB",
                  "child": [
                    {
                      "type": "TableOfContents",
                      "width": "matchParent",
                      "height": "wrapContent",
                      "title": "toc_title",
                      "sticky": true,
                      "maxDepth": 1,
                      "items": [
                        {
                          "id": "toc_syntax",
                          "label": "toc_row_syntax",
                          "anchor": "section_syntax",
                          "level": 1
                        },
                        {
                          "id": "toc_typed",
                          "label": "toc_row_typed",
                          "anchor": "section_typed",
                          "level": 1
                        },
                        {
                          "id": "toc_oneway",
                          "label": "toc_row_oneway",
                          "anchor": "section_oneway",
                          "level": 1
                        },
                        {
                          "id": "toc_no_logic",
                          "label": "toc_row_no_logic",
                          "anchor": "section_no_logic",
                          "level": 1
                        }
                      ],
                      "stickyOffset": 80
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
