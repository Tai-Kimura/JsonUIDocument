{
  "component": "Blur",
  "kebab": "blur",
  "aliasOf": null,
  "title": "Blur",
  "description": "Applies a platform-native blur effect (iOS UIBlurEffect / Android RenderEffect / Web CSS backdrop-filter) to everything behind this view.",
  "usage": "Use Blur for frosted-glass overlays (nav bars, modals, glass cards). Place Blur **above** the content to be blurred in the layout tree. `effectStyle` controls the visual variant.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Glass navbar",
              "language": "json",
              "code": "{\n  \"type\": \"Blur\",\n  \"effectStyle\": \"systemThinMaterial\",\n  \"width\": \"matchParent\",\n  \"height\": 64\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "Blurred background behind a title",
              "language": "json",
              "code": "{\n  \"type\": \"View\",\n  \"child\": [\n    { \"type\": \"Image\", \"srcName\": \"hero\", \"width\": \"matchParent\", \"height\": \"matchParent\" },\n    { \"type\": \"Blur\", \"effectStyle\": \"dark\", \"width\": \"matchParent\", \"height\": \"matchParent\" },\n    { \"type\": \"Label\", \"text\": \"@string/title\", \"fontColor\": \"#FFFFFF\", \"fontSize\": 32, \"gravity\": \"center\" }\n  ]\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
  "attributes": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "attr_effect_style",
              "name": "effectStyle",
              "type": "string",
              "required": "",
              "description": "Blur effect style",
              "note": "iOS UIBlurEffect.Style value: `extraLight` / `light` / `dark` / `regular` / `prominent` / `systemUltraThinMaterial` / `systemThinMaterial` / `systemMaterial` / `systemThickMaterial` / `systemChromeMaterial`. On Android / Web the closest visual approximation is used.",
              "platformDiff": {
                "swift_uikit": "UIVisualEffectView + UIBlurEffect(style:) に直接マップ。",
                "swift_swiftui": ".ultraThinMaterial / .thinMaterial / .regularMaterial / .thickMaterial / .chromeMaterial に対応（iOS 15+）。",
                "kotlin_compose": "Modifier.blur(radius) + 色付きオーバーレイで近似（Android 12+ は RenderEffect、それ以前は警告付き fallback）。",
                "kotlin_xml": "RenderEffect（API 31+）または RenderScript（それ以前）で実装。",
                "react": "CSS `backdrop-filter: blur(<Npx>)` に変換。対応ブラウザのみ動作。"
              },
              "enumValues": [
                "Light",
                "Dark",
                "ExtraLight"
              ]
            }
          ]
        }
      }
    ]
  },
