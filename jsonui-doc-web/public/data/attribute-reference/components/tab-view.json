{
  "component": "TabView",
  "kebab": "tab-view",
  "aliasOf": null,
  "title": "TabView",
  "description": {
    "en": "Tab bar with multiple pages. Each tab's content is a separate child view; only the active tab's content is in the foreground.",
    "ja": "複数ページを持つタブバー。各タブは独立した子 View を持ち、アクティブなタブのみ前面表示される。"
  },
  "usage": {
    "en": "Use TabView for top-level screen switching where users expect a persistent bar (iOS bottom, Android Material top). Do not nest TabViews — use a sidebar or segmented control for secondary navigation.",
    "ja": "ユーザーが常設タブバーを期待する最上位画面切替に使う（iOS はボトム、Android Material はトップ）。TabView のネストは避け、二次ナビはサイドバーや Segment を使う。"
  },
  "aliasNotice": null,
