{
  "component": "IconLabel",
  "kebab": "icon-label",
  "aliasOf": null,
  "title": "IconLabel",
  "description": "Label with a leading or trailing icon glyph. Used for button labels with icons, menu items, section rows with chevrons, and status indicators.",
  "usage": "Prefer IconLabel over manually composing View + Image + Label when the icon is a font glyph (SF Symbols, Material Icons, lucide). For raster images use a horizontal View + Image + Label instead.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "SF Symbol star",
              "language": "json",
              "code": "{\n  \"type\": \"IconLabel\",\n  \"iconName\": \"star.fill\",\n  \"iconPosition\": \"leading\",\n  \"text\": \"Favorite\",\n  \"fontSize\": 14,\n  \"fontColor\": \"#F59E0B\"\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "Trailing chevron row",
              "language": "json",
              "code": "{\n  \"type\": \"IconLabel\",\n  \"text\": \"@{sectionTitle}\",\n  \"iconName\": \"chevron.right\",\n  \"iconPosition\": \"trailing\",\n  \"iconSize\": 12,\n  \"fontSize\": 16\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Localized label with icon",
              "language": "json",
              "code": "{\n  \"type\": \"IconLabel\",\n  \"iconName\": \"favorite\",\n  \"iconPosition\": \"leading\",\n  \"text\": \"@string/favorite\",\n  \"fontSize\": 14\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
