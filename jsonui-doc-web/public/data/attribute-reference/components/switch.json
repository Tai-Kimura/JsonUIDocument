              "note": "Alias for `onValueChange`. Legacy naming."
            },
            {
              "id": "attr_on_value_change",
              "name": "onValueChange",
              "type": "binding",
              "required": "",
              "description": "Value change handler - binding only (@{functionName})",
              "note": "Fires with the new Boolean value. Mutually compatible with `value` binding; use onValueChange when side effects beyond state update are needed."
            },
