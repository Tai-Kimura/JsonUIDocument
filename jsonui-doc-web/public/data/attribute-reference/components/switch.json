{
  "component": "Switch",
  "kebab": "switch",
  "aliasOf": null,
  "title": "Switch",
  "description": "Binary ON/OFF control with an animated toggle thumb. Matches the host platform visually (iOS capsule / Android Material / Web custom).",
  "usage": "Use Switch when the action takes effect immediately (e.g., `Enable notifications`). For delayed commit (form submission) prefer CheckBox. Bind `value` (or the alias `isOn` / `checked`) to a mutable Boolean on the ViewModel.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Minimum",
              "language": "json",
              "code": "{\n  \"type\": \"Switch\",\n  \"value\": \"@{notificationsEnabled}\",\n  \"onValueChange\": \"@{onToggleNotifications}\"\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "With row label",
              "language": "json",
              "code": "{\n  \"type\": \"View\",\n  \"orientation\": \"horizontal\",\n  \"child\": [\n    { \"type\": \"Label\", \"text\": \"@string/enable_notifications\", \"weight\": 1 },\n    { \"type\": \"Switch\", \"value\": \"@{notificationsEnabled}\" }\n  ]\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Custom tint colors",
              "language": "json",
              "code": "{\n  \"type\": \"Switch\",\n  \"value\": \"@{darkMode}\",\n  \"onTintColor\": \"#2563EB\",\n  \"offTintColor\": \"#D1D5DB\",\n  \"thumbTintColor\": \"#FFFFFF\"\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
