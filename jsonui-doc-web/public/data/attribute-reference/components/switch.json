              "name": "enabled",
              "type": "boolean | binding",
              "required": "",
              "description": "Whether enabled (can be data binding)"
            },
            {
              "id": "attr_bind",
              "name": "bind",
              "type": "binding",
              "required": "",
              "description": "Two-way binding @{variable}",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_is_on",
              "name": "isOn",
              "type": "boolean | binding",
              "required": "",
              "description": "Switch state (binding for two-way)",
              "note": "Alias for `value`. iOS UISwitch-style naming.",
              "bindingDirection": "two-way"
