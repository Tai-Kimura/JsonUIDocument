              "id": "attr_value",
              "name": "value",
              "type": "boolean | binding",
              "required": "",
              "description": "Switch state alias (binding for two-way)",
              "note": "Two-way Boolean binding. Canonical attribute.",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_checked",
              "name": "checked",
              "type": "boolean | binding",
              "required": "",
              "description": "Switch state alias (binding for two-way)",
              "note": "Alias for `value`. Matches CheckBox/Radio naming for consistency.",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_tint_color",
              "name": "tintColor",
              "type": "string",
