              "name": "offTintColor",
              "type": "string | binding",
              "required": "",
              "description": "Off tint color - hex string or color name from colors.json (binding supported)",
              "note": "Track color when OFF.",
              "platform": "swift"
            },
            {
              "id": "attr_on_tint_color",
              "name": "onTintColor",
              "type": "string",
              "required": "",
              "description": "Track color when on - hex string or color name from colors.json",
              "note": "Track color when the switch is ON.",
              "platformDiff": {
                "swift_uikit": "UISwitch.onTintColor。",
                "swift_swiftui": "`.tint(onTintColor)`（iOS 15+）。",
                "kotlin_compose": "`SwitchColors(checkedTrackColor=...)`。",
                "kotlin_xml": "`android:trackTint` (checked state selector)。",
                "react": "CSS variable `--switch-on-bg` を上書き。"
              }
            },
            {
              "id": "attr_on_toggle",
              "name": "onToggle",
              "type": "string",
