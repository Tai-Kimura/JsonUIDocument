  "component": "EditText",
  "kebab": "edit-text",
  "aliasOf": "TextField",
  "title": "EditText",
  "description": {
    "en": "Android-native naming alias for TextField. Identical runtime behavior; exists to preserve attribute-name familiarity for Android engineers migrating from XML `EditText`.",
    "ja": "TextField の Android ネイティブ命名エイリアス。実行時動作は同一。XML `EditText` から移行する Android エンジニアの属性名の馴染みを保つために存在。"
  },
  "usage": {
    "en": "Prefer TextField in new cross-platform code. Use EditText when porting existing Android XML layouts verbatim.",
    "ja": "新規クロスプラットフォームコードでは TextField を推奨。既存 Android XML レイアウトをそのまま移植するときに EditText を使う。"
  },
  "aliasNotice": {
    "en": "Alias of TextField. Identical runtime behavior.",
    "ja": "TextField のエイリアス。実行時動作は同一。"
  },
