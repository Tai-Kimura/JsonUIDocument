{
  "component": "TextField",
  "kebab": "text-field",
  "aliasOf": null,
  "title": "TextField",
  "description": "Single-line text input for short user-entered strings. For multi-line input use TextView. For secure input toggle `secure: true`.",
  "usage": "TextField owns its text state via two-way binding. The ViewModel declares the property as mutable (`@Published var text: String` on iOS / `MutableStateFlow<String>` on Android / plain mutable on web). TextField writes back through the bound property on every commit.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Minimum two-way binding",
              "language": "json",
              "code": "{\n  \"type\": \"TextField\",\n  \"text\": \"@{email}\",\n  \"hint\": \"@string/email_placeholder\",\n  \"contentType\": \"emailAddress\",\n  \"width\": \"matchParent\"\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "With validation error",
              "language": "json",
              "code": "{\n  \"type\": \"View\",\n  \"orientation\": \"vertical\",\n  \"child\": [\n    {\n      \"type\": \"TextField\",\n      \"text\": \"@{email}\",\n      \"hint\": \"@string/email_placeholder\",\n      \"contentType\": \"emailAddress\",\n      \"onTextChange\": \"@{onEmailChanged}\"\n    },\n    {\n      \"type\": \"Label\",\n      \"text\": \"@{emailError}\",\n      \"visibility\": \"@{emailError != null && emailError != ''}\",\n      \"fontColor\": \"#EF4444\",\n      \"fontSize\": 12\n    }\n  ]\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Password",
              "language": "json",
              "code": "{\n  \"type\": \"TextField\",\n  \"text\": \"@{password}\",\n  \"secure\": true,\n  \"contentType\": \"password\",\n  \"hint\": \"@string/password_placeholder\"\n}",
              "required": ""
            },
            {
              "id": "example_4",
              "title": "Numeric with max length",
              "language": "json",
              "code": "{\n  \"type\": \"TextField\",\n  \"text\": \"@{age}\",\n  \"pattern\": \"^[0-9]*$\",\n  \"maxLength\": 3,\n  \"hint\": \"18\"\n}",
              "required": ""
            },
            {
              "id": "example_5",
              "title": "Submit on return",
              "language": "json",
              "code": "{\n  \"type\": \"TextField\",\n  \"text\": \"@{query}\",\n  \"hint\": \"@string/search_placeholder\",\n  \"returnKeyType\": \"search\",\n  \"onShouldReturn\": \"@{onSubmitSearch}\"\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
  "attributes": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "attr_text",
              "name": "text",
              "type": "string | binding",
              "required": "",
              "description": "Text content (binding for two-way)",
              "note": "Always two-way. Must bind to a mutable ViewModel property. Use `onTextChange` for non-binding side effects.",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_hint",
              "name": "hint",
              "type": "string",
              "required": "",
              "description": "Placeholder text (primary)",
              "note": "Placeholder shown when empty. Accepts `@string/key`. Color controlled by `hintColor`."
            },
            {
              "id": "attr_content_type",
              "name": "contentType",
              "type": "string | binding",
              "required": "",
              "description": "Content type for autofill (binding supported)",
              "note": "Hints the keyboard / autofill behavior. Common values: `emailAddress`, `password`, `username`, `telephoneNumber`, `URL`, `fullStreetAddress`, `postalCode`, `creditCardNumber`. Maps to `UITextContentType` on iOS, `inputType` on Android, `autocomplete` on Web."
            },
            {
              "id": "attr_secure",
              "name": "secure",
              "type": "boolean | binding",
              "required": "",
              "description": "Secure text entry for passwords (can be data binding)",
              "note": "Boolean. When `true`, characters are obscured. Required for password fields. Pair with `contentType: 'password'` for autofill."
            },
            {
              "id": "attr_max_length",
              "name": "maxLength",
              "type": "number",
              "required": "",
              "description": "Maximum input length",
              "note": "Positive integer. Enforced at platform level; paste beyond limit is truncated silently."
            },
            {
              "id": "attr_pattern",
              "name": "pattern",
              "type": "string",
              "required": "",
              "description": "Input validation pattern",
              "note": "Regex string. Input is restricted to matching characters on commit. Use in combination with `maxLength` for strict format fields.",
              "platform": "react"
            },
            {
              "id": "attr_required",
              "name": "required",
              "type": "boolean",
              "required": "",
              "description": "Required field validation",
              "note": "Boolean. When `true`, web forms mark the field as required (HTML `required` attribute). Not enforced at runtime on native platforms — ViewModel must validate.",
              "platform": "react"
            },
            {
              "id": "attr_return_key_type",
              "name": "returnKeyType",
              "type": "string",
              "required": "",
              "description": "Return key type",
              "note": "`default` / `go` / `done` / `next` / `send` / `search`. Affects the keyboard's return-key label. Maps to `enterkeyhint` on Web.",
              "enumValues": [
                "Done",
                "Go",
                "Next",
                "Return",
                "Search",
                "Send",
                "Continue",
                "Join",
                "Route",
                "Yahoo",
                "Google"
              ]
            },
            {
              "id": "attr_on_should_return",
              "name": "onShouldReturn",
              "type": "string",
              "required": "",
              "description": "Should return event handler (return true to allow)",
              "note": "Handler fired when user presses return/enter. Return value controls whether the field resigns focus (Swift convention).",
              "platform": "swift"
            },
            {
              "id": "attr_on_text_change",
              "name": "onTextChange",
              "type": "string",
              "required": "",
              "description": "Text change event handler",
              "note": "Fires on every keystroke with the new value. Use sparingly — for two-way binding the `text` attribute already syncs; use `onTextChange` only when additional side effects (validation, debounced search) are needed."
            },
            {
              "id": "attr_on_focus",
              "name": "onFocus",
              "type": "string",
              "required": "",
              "description": "Focus event handler",
              "note": "Focus gained. Fires before first keystroke."
            },
            {
              "id": "attr_on_blur",
              "name": "onBlur",
              "type": "string",
              "required": "",
              "description": "Blur event handler",
              "note": "Focus lost. Good place to run validation."
            },
            {
              "id": "attr_on_begin_editing",
              "name": "onBeginEditing",
              "type": "string",
              "required": "",
              "description": "Begin editing event handler"
            },
            {
