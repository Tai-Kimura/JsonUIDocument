              "name": "onEndEditing",
              "type": "string",
              "required": "",
              "description": "End editing event handler"
            },
            {
              "id": "attr_next_focus",
              "name": "nextFocus",
              "type": "string",
              "required": "",
              "description": "ID of the next field to focus on submit (for focus chain)",
              "note": "ID of the next TextField to focus when user taps `next` key. Enables keyboard-driven form traversal without tapping each field."
            },
            {
