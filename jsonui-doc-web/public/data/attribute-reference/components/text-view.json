{
  "component": "TextView",
  "kebab": "text-view",
  "aliasOf": null,
  "title": "TextView",
  "description": "Multi-line text input for long-form user-entered strings (comments, descriptions, messages). Grows vertically with content unless constrained by `height`.",
  "usage": "Use TextView when expected input exceeds one line. For messaging UI, pair with a fixed-height container and a Scroll.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Auto-growing multi-line",
              "language": "json",
              "code": "{\n  \"type\": \"TextView\",\n  \"text\": \"@{description}\",\n  \"hint\": \"@string/description_placeholder\",\n  \"width\": \"matchParent\"\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "Character counter",
              "language": "json",
              "code": "{\n  \"type\": \"View\",\n  \"orientation\": \"vertical\",\n  \"child\": [\n    { \"type\": \"TextView\", \"text\": \"@{bio}\", \"maxLength\": 160 },\n    { \"type\": \"Label\", \"text\": \"@{bio.length}/160\", \"fontSize\": 12, \"fontColor\": \"#9CA3AF\" }\n  ]\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Fixed height (internal scroll)",
              "language": "json",
              "code": "{\n  \"type\": \"TextView\",\n  \"text\": \"@{longText}\",\n  \"width\": \"matchParent\",\n  \"height\": 200\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
