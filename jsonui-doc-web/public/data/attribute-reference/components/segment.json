{
  "component": "Segment",
  "kebab": "segment",
  "aliasOf": null,
  "title": "Segment",
  "description": "Segmented control — mutually exclusive horizontal button group. Shows 2–5 options at a time.",
  "usage": "Use when options are short (1–2 words) and all visible at once benefits the user (filters, toggles). Beyond 5 options use SelectBox. For one-shot action button bars (not selection), set `momentary: true`.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Filter segment",
              "language": "json",
              "code": "{\n  \"type\": \"Segment\",\n  \"selectedIndex\": \"@{filterIndex}\",\n  \"items\": [\n    { \"label\": \"@string/all\", \"value\": \"all\" },\n    { \"label\": \"@string/active\", \"value\": \"active\" },\n    { \"label\": \"@string/done\", \"value\": \"done\" }\n  ],\n  \"onValueChange\": \"@{onFilterChanged}\"\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "Icon-only segment",
              "language": "json",
              "code": "{\n  \"type\": \"Segment\",\n  \"selectedIndex\": \"@{viewModeIndex}\",\n  \"items\": [\n    { \"icon\": \"list.bullet\", \"value\": \"list\" },\n    { \"icon\": \"square.grid.2x2\", \"value\": \"grid\" }\n  ]\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Momentary (action bar)",
              "language": "json",
              "code": "{\n  \"type\": \"Segment\",\n  \"momentary\": true,\n  \"items\": [\n    { \"label\": \"B\", \"value\": \"bold\" },\n    { \"label\": \"I\", \"value\": \"italic\" },\n    { \"label\": \"U\", \"value\": \"underline\" }\n  ],\n  \"onValueChange\": \"@{onFormat}\"\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
  "attributes": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "attr_items",
              "name": "items",
              "type": "array",
              "required": "required",
              "description": "Segment items array",
              "note": "Array of `{ label?, icon?, value }`. At least `label` or `icon` is required per entry."
            },
            {
              "id": "attr_tint_color",
              "name": "tintColor",
              "type": "string",
              "required": "",
              "description": "Tint color - hex string or color name from colors.json",
              "note": "Primary color for selected segment background and text."
            },
            {
              "id": "attr_apportions_segment_widths_by_content",
              "name": "apportionsSegmentWidthsByContent",
              "type": "boolean",
              "required": "",
              "description": "Size segments by content",
              "note": "iOS UISegmentedControl attribute. When `true`, each segment sizes to its content; when `false`, all segments are equal width.",
              "platform": "swift"
            },
            {
              "id": "attr_momentary",
              "name": "momentary",
              "type": "boolean",
              "required": "",
              "description": "Momentary selection mode",
              "note": "Boolean. When `true`, segments act like action buttons (no persistent selected state). Default `false`.",
              "platform": "swift"
            },
            {
              "id": "attr_normal_color",
              "name": "normalColor",
              "type": "string | binding",
              "required": "",
              "description": "Normal state color - hex string or color name from colors.json (binding supported)",
              "note": "Text color for unselected segments."
            },
            {
              "id": "attr_on_value_change",
              "name": "onValueChange",
              "type": "binding",
              "required": "",
              "description": "Value change handler - binding only (@{functionName})",
              "note": "Fires with the new selected value (not index)."
            },
            {
              "id": "attr_selected_color",
              "name": "selectedColor",
              "type": "string | binding",
              "required": "",
              "description": "Selected state color - hex string or color name from colors.json (binding supported)",
              "note": "Text color when selected. Defaults to contrast of `tintColor`."
            },
            {
              "id": "attr_selected_index",
              "name": "selectedIndex",
              "type": "number | binding",
              "required": "",
              "description": "Initially selected index (binding for two-way)",
              "note": "Two-way Int binding. `-1` means nothing selected (in `momentary` mode, always `-1` between taps).",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_value_change",
              "name": "valueChange",
              "type": "string",
              "required": "",
              "description": "Value change event"
            }
          ]
        }
      }
    ]
  },
