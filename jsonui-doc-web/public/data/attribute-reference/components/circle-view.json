{
  "component": "CircleView",
  "kebab": "circle-view",
  "aliasOf": null,
  "title": "CircleView",
  "description": "Circular container. Equivalent to a View with `cornerRadius: width/2` and clipping, but guarantees a perfect circle regardless of aspect.",
  "usage": "Use CircleView for avatars, badges, and circular icons. Always specify equal `width` and `height` (or just `width`; height auto-matches).",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Avatar",
              "language": "json",
              "code": "{\n  \"type\": \"CircleView\",\n  \"width\": 48,\n  \"height\": 48,\n  \"child\": [\n    { \"type\": \"NetworkImage\", \"url\": \"@{user.avatarUrl}\", \"width\": 48, \"height\": 48, \"contentMode\": \"aspectFill\" }\n  ]\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "Unread count badge",
              "language": "json",
              "code": "{\n  \"type\": \"CircleView\",\n  \"width\": 24,\n  \"height\": 24,\n  \"background\": \"#EF4444\",\n  \"child\": [\n    { \"type\": \"Label\", \"text\": \"@{unreadCount}\", \"fontColor\": \"#FFFFFF\", \"fontSize\": 12, \"gravity\": \"center\" }\n  ]\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Colored status dot",
              "language": "json",
              "code": "{\n  \"type\": \"CircleView\",\n  \"width\": 10,\n  \"height\": 10,\n  \"background\": \"@{statusColor}\"\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
