{
  "component": "CheckBox",
  "kebab": "check-box",
  "aliasOf": null,
  "title": "CheckBox",
  "description": "Binary checkbox. Unlike Radio, CheckBoxes are independent even when visually grouped — each maintains its own state.",
  "usage": "Use CheckBox for zero-or-more selections (terms-of-service agreement, interest multi-select, filter multi-select). For exclusive one-of-N selection use Radio.",
  "aliasNotice": null,
  "examples": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "example_1",
              "title": "Single terms checkbox",
              "language": "json",
              "code": "{\n  \"type\": \"CheckBox\",\n  \"checked\": \"@{agreeToTerms}\",\n  \"label\": \"@string/accept_terms\",\n  \"onValueChange\": \"@{onAgreeChanged}\"\n}",
              "required": ""
            },
            {
              "id": "example_2",
              "title": "Custom check icons",
              "language": "json",
              "code": "{\n  \"type\": \"CheckBox\",\n  \"checked\": \"@{subscribed}\",\n  \"src\": \"check_off\",\n  \"onSrc\": \"check_on\",\n  \"label\": \"@string/subscribe\"\n}",
              "required": ""
            },
            {
              "id": "example_3",
              "title": "Without label (wrapped externally)",
              "language": "json",
              "code": "{\n  \"type\": \"View\",\n  \"orientation\": \"horizontal\",\n  \"child\": [\n    { \"type\": \"CheckBox\", \"checked\": \"@{selected}\" },\n    { \"type\": \"Label\", \"text\": \"@{item.title}\", \"weight\": 1 }\n  ]\n}",
              "required": ""
            }
          ]
        }
      }
    ]
  },
  "attributes": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "attr_text",
              "name": "text",
              "type": "string | binding",
              "required": "",
              "description": "Checkbox label (alias, can be data binding)"
            },
            {
              "id": "attr_value",
              "name": "value",
              "type": "any",
              "required": "",
              "description": "Associated value when checked",
              "note": "Alias for `checked`."
            },
            {
              "id": "attr_checked",
              "name": "checked",
              "type": "boolean | binding",
              "required": "",
              "description": "Checked state alias (binding for two-way)",
              "note": "Two-way Boolean binding. Canonical attribute.",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_src",
              "name": "src",
              "type": "string",
              "required": "",
              "description": "Icon name for unchecked state (alias)",
              "note": "Unchecked-state image name. Use with `onSrc` for custom glyphs (non-standard check visuals)."
            },
            {
              "id": "attr_icon",
              "name": "icon",
              "type": "string",
              "required": "",
              "description": "Icon name for unchecked state",
              "note": "Alias for `src`."
            },
            {
              "id": "attr_font_size",
              "name": "fontSize",
              "type": "number | binding",
              "required": "",
              "description": "Font size (binding supported)"
            },
            {
              "id": "attr_font_color",
              "name": "fontColor",
              "type": "string | binding",
              "required": "",
              "description": "Text color - hex string or color name from colors.json (binding supported)"
            },
            {
              "id": "attr_spacing",
              "name": "spacing",
              "type": "number | binding",
              "required": "",
              "description": "Space between icon and text (binding supported)",
              "note": "Gap between checkbox glyph and label (pt/dp/px). Default 8."
            },
            {
              "id": "attr_enabled",
              "name": "enabled",
              "type": "boolean | binding",
              "required": "",
              "description": "Whether enabled (can be data binding)"
            },
            {
              "id": "attr_bind",
              "name": "bind",
              "type": "binding",
              "required": "",
              "description": "Two-way binding @{variable}",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_font",
              "name": "font",
              "type": "string | binding",
              "required": "",
              "description": "Font name (binding supported)"
            },
            {
              "id": "attr_is_on",
              "name": "isOn",
              "type": "boolean | binding",
              "required": "",
              "description": "Checked state (binding for two-way)",
              "note": "Alias for `checked` (iOS-style naming).",
              "bindingDirection": "two-way"
            },
            {
              "id": "attr_label",
              "name": "label",
              "type": "string | binding",
              "required": "",
              "description": "Checkbox label (can be data binding)",
              "note": "Inline label rendered to the right of the checkbox. Tapping the label toggles the checkbox. Accepts `@string/key`."
            },
            {
              "id": "attr_on_src",
              "name": "onSrc",
              "type": "string",
              "required": "",
              "description": "Selected icon name (alias)",
              "note": "Checked-state image name."
            },
            {
              "id": "attr_on_value_change",
              "name": "onValueChange",
              "type": "binding",
              "required": "",
              "description": "Value change handler - binding only (@{functionName})",
              "note": "Fires with the new Boolean value. Use when side effects beyond `checked` binding are needed."
            },
            {
              "id": "attr_selected_icon",
              "name": "selectedIcon",
              "type": "string",
              "required": "",
              "description": "Selected icon name",
              "note": "Alias for `onSrc`."
            }
          ]
        }
      }
    ]
  },
