        "cells": {
          "data": [
            {
              "id": "overview_bind",
              "name": "bind",
              "type": "string | object",
              "summary": {
                "en": "Alias for `binding`.",
                "ja": "`binding` のエイリアス。"
              },
              "anchorUrl": "#attr-bind"
            },
            {
              "id": "overview_binding",
              "name": "binding",
              "type": "string | object",
              "summary": {
                "en": "Explicit binding declaration for attributes that do not use the `@{...}` inline syntax. Rarely us…",
                "ja": "`@{...}` 構文を使わない属性に対する明示的 binding 宣言。直接使われることは稀 — 通常は属性値内の `@{...}` で binding する。"
              },
              "anchorUrl": "#attr-binding"
            },
            {
              "id": "overview_bindingScript",
              "name": "bindingScript",
              "type": "string",
              "summary": {
                "en": "Inline JavaScript expression evaluated against the ViewModel. Use for complex derived values wher…",
                "ja": "ViewModel に対して評価されるインライン JavaScript 式。`@{...}` では表現しきれない複雑な導出値に使う。spec の `stateManagement.compute…"
              },
              "anchorUrl": "#attr-bindingScript"
            },
            {
              "id": "overview_binding_group",
              "name": "binding_group",
              "type": "string | array",
              "summary": {
                "en": "Groups multiple bindings so they re-evaluate together. Use when several attributes on the same el…",
                "ja": "複数の binding をまとめて再評価させる。同一要素の複数属性をアトミックに更新したいときに使う。"
              },
              "anchorUrl": "#attr-binding_group"
            },
            {
              "id": "overview_binding_id",
              "name": "binding_id",
              "type": "string",
              "summary": {
                "en": "Stable identifier for a specific binding. Used by the Hot Loader to route targeted updates to the…",
                "ja": "特定の binding の安定識別子。Hot Loader が更新を適切な要素に振り分けるのに使う。"
              },
              "anchorUrl": "#attr-binding_id"
            },
            {
              "id": "overview_data",
              "name": "data",
              "type": "array",
              "summary": {
                "en": "Declares the ViewModel properties this Layout segment expects. Appears at the top of a Layout as …",
                "ja": "この Layout セグメントが ViewModel に期待するプロパティを宣言。Layout 先頭に `{ \"data\": [...] }` として現れる。"
              },
              "anchorUrl": "#attr-data"
            },
            {
              "id": "overview_propertyName",
              "name": "propertyName",
              "type": "string",
              "summary": {
                "en": "Specifies the ViewModel property name that this element's value binding writes to. Sometimes requ…",
                "ja": "この要素の値 binding が書き戻す ViewModel プロパティ名を指定。属性-プロパティのマッピングが自動でないカスタムコンポーネントで必要になる。"
              },
              "anchorUrl": "#attr-propertyName"
            },
            {
              "id": "overview_shared_data",
              "name": "shared_data",
              "type": "object",
              "summary": {
                "en": "Declares data shared with parent screens. Used in include'd partials to propagate state upward.",
                "ja": "親画面と共有するデータを宣言。include された部分 Layout から状態を上位に伝搬させるのに使う。"
              },
              "anchorUrl": "#attr-shared_data"
            },
            {
              "id": "overview_variables",
              "name": "variables",
              "type": "object",
              "summary": {
                "en": "Alternative to `data`: compact local variable declarations. Used in cell layouts that receive ite…",
                "ja": "`data` の代替: コンパクトなローカル変数宣言。`@{item.*}` で item データを受ける cell レイアウトで使う。"
              },
              "anchorUrl": "#attr-variables"
            }
          ]
        }
      }
    ]
  },
