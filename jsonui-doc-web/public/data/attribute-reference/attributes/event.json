  "overviewRows": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "overview_events",
              "name": "events",
              "type": "object",
              "summary": {
                "en": "Batch-declare multiple event handlers in one object. Alternative to individual `onClick` / `onLon…",
                "ja": "複数のイベントハンドラを 1 オブジェクトでまとめて宣言。個別の `onClick` / `onLongPress` より読みやすいとき使う。"
              },
              "anchorUrl": "#attr-events"
            },
            {
              "id": "overview_onAppear",
              "name": "onAppear",
              "type": "string",
              "summary": {
                "en": "Fired when the component becomes visible (mount / re-mount). Useful for analytics and lazy data f…",
                "ja": "コンポーネントが可視になったとき（マウント／再マウント時）に発火。アナリティクスや遅延データ取得に有用。"
              },
              "anchorUrl": "#attr-onAppear"
            },
            {
              "id": "overview_onClick",
              "name": "onClick",
              "type": "binding",
              "summary": {
                "en": "Tap / click. Fires on single tap after gesture recognition (≈0–50 ms). Required on Button for int…",
                "ja": "タップ／クリック。ジェスチャ認識後（約 0〜50ms）、シングルタップで発火。Button では必須。"
              },
              "anchorUrl": "#attr-onClick"
            },
            {
              "id": "overview_onDisappear",
              "name": "onDisappear",
              "type": "string",
              "summary": {
                "en": "Fired when the component is unmounted.",
                "ja": "コンポーネントがアンマウントされたとき発火。"
              },
              "anchorUrl": "#attr-onDisappear"
            },
            {
              "id": "overview_onLongPress",
              "name": "onLongPress",
              "type": "binding",
              "summary": {
                "en": "Long-press event. Default threshold: iOS 500 ms / Android 500 ms / Web 600 ms.",
                "ja": "長押しイベント。既定閾値は iOS 500ms / Android 500ms / Web 600ms。"
              },
              "anchorUrl": "#attr-onLongPress"
            },
            {
              "id": "overview_onPan",
              "name": "onPan",
              "type": "binding",
              "summary": {
                "en": "Pan gesture (drag) events. Receives a vector `{ dx, dy }` per frame.",
                "ja": "パンジェスチャ（ドラッグ）イベント。フレームごとに `{ dx, dy }` を受け取る。"
              },
              "anchorUrl": "#attr-onPan"
            },
            {
              "id": "overview_onPinch",
              "name": "onPinch",
              "type": "binding",
              "summary": {
                "en": "Pinch gesture (two-finger zoom). Receives a `scale` factor per frame.",
                "ja": "ピンチジェスチャ（2 本指ズーム）。フレームごとに `scale` 係数を受け取る。"
              },
              "anchorUrl": "#attr-onPinch"
            },
            {
              "id": "overview_onclick",
              "name": "onclick",
              "type": "string | array",
              "summary": {
                "en": "Lowercase alias for `onClick` (HTML-style).",
                "ja": "`onClick` の小文字エイリアス（HTML 風）。"
              },
              "anchorUrl": "#attr-onclick"
            },
            {
              "id": "overview_scripts",
              "name": "scripts",
              "type": "array",
              "summary": {
                "en": "Inline scripts that run on specific lifecycle events (e.g., `onMount`). Use sparingly — prefer Vi…",
                "ja": "特定のライフサイクルイベント（例: `onMount`）で実行されるインラインスクリプト。控えめに使い、通常は ViewModel のイベントハンドラを優先する。"
              },
              "anchorUrl": "#attr-scripts"
            }
          ]
        }
      }
    ]
  },
