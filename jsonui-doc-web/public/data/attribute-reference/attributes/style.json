  "overviewRows": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "overview_background",
              "name": "background",
              "type": "string | binding",
              "summary": {
                "en": "Background color. Accepts hex `#RGB`/`#RRGGBB`/`#RRGGBBAA`, named colors, or `@color/token`. For …",
                "ja": "背景色。hex `#RGB`/`#RRGGBB`/`#RRGGBBAA`、色名、または `@color/token`。グラデーションは `gradient` 属性または GradientView…"
              },
              "anchorUrl": "#attr-background"
            },
            {
              "id": "overview_borderColor",
              "name": "borderColor",
              "type": "string | binding",
              "summary": {
                "en": "Border color. Requires `borderWidth` for the border to render.",
                "ja": "ボーダー色。描画には `borderWidth` の指定が必要。"
              },
              "anchorUrl": "#attr-borderColor"
            },
            {
              "id": "overview_borderStyle",
              "name": "borderStyle",
              "type": "string",
              "summary": {
                "en": "`solid` / `dashed` / `dotted`. Web supports all; iOS/Android default is `solid`.",
                "ja": "`solid` / `dashed` / `dotted`。Web は全対応、iOS/Android は既定 `solid`。"
              },
              "anchorUrl": "#attr-borderStyle"
            },
            {
              "id": "overview_borderWidth",
              "name": "borderWidth",
              "type": "number | binding",
              "summary": {
                "en": "Border thickness in pt/dp/px.",
                "ja": "ボーダーの太さ（pt/dp/px）。"
              },
              "anchorUrl": "#attr-borderWidth"
            },
            {
              "id": "overview_clipToBounds",
              "name": "clipToBounds",
              "type": "boolean | binding",
              "summary": {
                "en": "Boolean. When `true`, children that overflow the View are clipped.",
                "ja": "Boolean。`true` で境界を超える子要素を切り取る。"
              },
              "anchorUrl": "#attr-clipToBounds"
            },
            {
              "id": "overview_cornerRadius",
              "name": "cornerRadius",
              "type": "number | binding",
              "summary": {
                "en": "Rounded corners in pt/dp/px. Accepts a number (uniform) or array `[tl, tr, br, bl]` for per-corne…",
                "ja": "角丸半径（pt/dp/px）。数値（全辺同一）または配列 `[左上, 右上, 右下, 左下]` で角ごとに指定可。"
              },
              "anchorUrl": "#attr-cornerRadius"
            },
            {
              "id": "overview_defaultBackground",
              "name": "defaultBackground",
              "type": "string | binding",
              "summary": {
                "en": "Background color in the default (non-interactive) state. Base layer for the pressed / disabled ov…",
                "ja": "デフォルト（非操作）状態の背景色。押下・disabled オーバーレイの下地。"
              },
              "anchorUrl": "#attr-defaultBackground"
            },
            {
              "id": "overview_disabledBackground",
              "name": "disabledBackground",
              "type": "string | binding",
              "summary": {
                "en": "Background color when `enabled: false`.",
                "ja": "`enabled: false` のときの背景色。"
              },
              "anchorUrl": "#attr-disabledBackground"
            },
            {
              "id": "overview_effectStyle",
              "name": "effectStyle",
              "type": "string",
              "summary": {
                "en": "Visual effect preset. Used by Blur; platform-specific blur / material style value.",
                "ja": "視覚効果のプリセット。Blur で使用、プラットフォーム固有のぼかし／マテリアルスタイル値。"
              },
              "anchorUrl": "#attr-effectStyle"
            },
            {
              "id": "overview_highlightBackground",
              "name": "highlightBackground",
              "type": "string | binding",
              "summary": {
                "en": "Background color shown when the component is highlighted (e.g., pressed).",
                "ja": "ハイライト状態（押下など）の背景色。"
              },
              "anchorUrl": "#attr-highlightBackground"
            },
            {
              "id": "overview_shadow",
              "name": "shadow",
              "type": "string | object",
              "summary": {
                "en": "Drop shadow object: `{ color, offsetX, offsetY, radius, opacity }`. Applied to the entire View bo…",
                "ja": "ドロップシャドウのオブジェクト: `{ color, offsetX, offsetY, radius, opacity }`。View の全体境界に適用される。"
              },
              "anchorUrl": "#attr-shadow"
            },
            {
              "id": "overview_style",
              "name": "style",
              "type": "string",
              "summary": {
                "en": "Preset style name. Defined in `docs/screens/styles/*.json`. Accepts a single name or array of nam…",
                "ja": "プリセットスタイル名。`docs/screens/styles/*.json` で定義。単一名または名前配列を受け付け、後出の値が前を上書き。"
              },
              "anchorUrl": "#attr-style"
            },
            {
              "id": "overview_tapBackground",
              "name": "tapBackground",
              "type": "string | binding",
              "summary": {
                "en": "Button-specific. Background color shown during tap-down. Reverts to `background` on release.",
                "ja": "Button 専用。押下中に表示される背景色。解放で `background` に戻る。"
              },
              "anchorUrl": "#attr-tapBackground"
            },
            {
              "id": "overview_tintColor",
              "name": "tintColor",
              "type": "string | binding",
              "summary": {
                "en": "Color applied to tinted content (monochrome icons, progress tracks, switches). Specific component…",
                "ja": "tint 可能なコンテンツ（モノクロアイコン、progress の track、switch など）に適用される色。何が tint されるかはコンポーネント実装依存。"
              },
              "anchorUrl": "#attr-tintColor"
            }
          ]
        }
      }
    ]
  },
