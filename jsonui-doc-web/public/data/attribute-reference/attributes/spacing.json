            {
              "id": "attr_paddings",
              "name": "paddings",
              "type": "number | array",
              "required": "",
              "description": "Padding as single value or [top, right, bottom, left]",
              "summary": "Inner space between component bounds and its content. Accepts `[top, right, bottom, left]`, a single number for all sides, or `[vertical, horizontal]`.",
              "values": [
                {
                  "value": "[t, r, b, l]",
                  "description": "4-element numeric array."
                },
                {
                  "value": "<number>",
                  "description": "Same value applied to all four sides."
                },
                {
                  "value": "[tb, lr]",
                  "description": "2-element shorthand: top-bottom and left-right."
                }
              ],
              "examples": [
                {
                  "language": "json",
                  "code": "{ \"type\": \"View\", \"paddings\": [16, 24, 16, 24] }"
