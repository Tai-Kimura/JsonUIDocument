        "cells": {
          "data": [
            {
              "id": "overview_className",
              "name": "className",
              "type": "string",
              "summary": {
                "en": "Web-only. Additional CSS class names appended to the generated element.",
                "ja": "Web 専用。生成要素に追加される CSS クラス名。"
              },
              "anchorUrl": "#attr-className"
            },
            {
              "id": "overview_generatedBy",
              "name": "generatedBy",
              "type": "string",
              "summary": {
                "en": "Set by the generator to identify the spec that produced this file. Do not edit by hand; it drives…",
                "ja": "生成器がこのファイルを生んだ spec を記録するフィールド。手編集禁止、`jui verify` の根拠になる。"
              },
              "anchorUrl": "#attr-generatedBy"
            },
            {
              "id": "overview_id",
              "name": "id",
              "type": "string",
              "summary": {
                "en": "Unique identifier within the layout. Required for ViewModel references and test-runner selectors.…",
                "ja": "Layout 内の一意識別子。ViewModel 参照とテストランナーの selector に必須。命名規則: `<screen>_<purpose>`。"
              },
              "anchorUrl": "#attr-id"
            },
            {
              "id": "overview_include",
              "name": "include",
              "type": "string",
              "summary": {
                "en": "Reference to another Layout file, inlined at this position. Path is relative to the layouts root;…",
                "ja": "別の Layout ファイルを参照し、この位置にインライン展開。パスは layouts ルートからの相対、拡張子なし。"
              },
              "anchorUrl": "#attr-include"
            },
            {
              "id": "overview_partial",
              "name": "partial",
              "type": "boolean",
              "summary": {
                "en": "Marks the file as a partial layout that is only usable via `include`. Prevents direct routing.",
                "ja": "このファイルが `include` 経由でのみ使えるパーシャル Layout であることをマーク。直接ルーティングを防ぐ。"
              },
              "anchorUrl": "#attr-partial"
            },
            {
              "id": "overview_tag",
              "name": "tag",
              "type": "number | binding",
              "summary": {
                "en": "Arbitrary marker string attached to the view. Useful for runtime debugging / analytics without po…",
                "ja": "view に付ける任意のマーカー文字列。`id` を汚さずに実行時デバッグ／アナリティクスに使う。"
              },
              "anchorUrl": "#attr-tag"
            },
            {
              "id": "overview_testId",
              "name": "testId",
              "type": "string",
              "summary": {
                "en": "Test-only identifier separate from `id`. Use when the test selector should not affect runtime acc…",
                "ja": "`id` とは別のテスト専用識別子。ランタイムの accessibility ID に影響させたくないときに使う。"
              },
              "anchorUrl": "#attr-testId"
            },
            {
              "id": "overview_type",
              "name": "type",
              "type": "string",
              "summary": {
                "en": "The component type (`Label`, `Button`, `View`, ...). Required on every node. Not typically discus…",
                "ja": "コンポーネント型（`Label`, `Button`, `View` など）。全ノードで必須。ユーザー向け属性としては通常議論されないが、網羅のためここに記載。"
              },
              "anchorUrl": "#attr-type"
            }
          ]
        }
      }
    ]
  },
