  "overviewRows": {
    "sections": [
      {
        "cells": {
          "data": [
            {
              "id": "overview_alpha",
              "name": "alpha",
              "type": "number | binding",
              "summary": {
                "en": "0.0–1.0. Translucency. `alpha: 0` is visually hidden but still receives touches — use `visibility…",
                "ja": "0.0〜1.0。不透明度。`alpha: 0` は見えなくても touch は受け付ける。完全無効化には `visibility` を使う。"
              },
              "anchorUrl": "#attr-alpha"
            },
            {
              "id": "overview_canTap",
              "name": "canTap",
              "type": "boolean | binding",
              "summary": {
                "en": "Boolean. When `false`, `onClick` handlers are not invoked. Use to disable interaction without vis…",
                "ja": "Boolean。`false` で `onClick` ハンドラが呼ばれない。見た目を変えず操作のみ無効化したいときに使う。"
              },
              "anchorUrl": "#attr-canTap"
            },
            {
              "id": "overview_confirmationDialog",
              "name": "confirmationDialog",
              "type": "object",
              "summary": {
                "en": "If set to an object with `title` / `message` / `confirmText`, shows a native confirm dialog befor…",
                "ja": "`title` / `message` / `confirmText` を含むオブジェクトを指定すると、`onClick` 実行前にネイティブ確認ダイアログを表示。"
              },
              "anchorUrl": "#attr-confirmationDialog"
            },
            {
              "id": "overview_enabled",
              "name": "enabled",
              "type": "boolean | binding",
              "summary": {
                "en": "Boolean. When `false`, the component ignores user interaction and applies its disabled styling (d…",
                "ja": "Boolean。`false` でユーザー操作を無視し、disabled スタイル（減光／彩度低下）が適用される。"
              },
              "anchorUrl": "#attr-enabled"
            },
            {
              "id": "overview_hidden",
              "name": "hidden",
              "type": "boolean | binding",
              "summary": {
                "en": "Shorthand for `visibility: 'gone'`. Boolean-valued. Deprecated for new code — prefer explicit `vi…",
                "ja": "`visibility: 'gone'` のショートハンド。Boolean 値。新規コードでは非推奨、明示的な `visibility` を使う。"
              },
              "anchorUrl": "#attr-hidden"
            },
            {
              "id": "overview_opacity",
              "name": "opacity",
              "type": "number | binding",
              "summary": {
                "en": "Alias for `alpha` (CSS-style naming).",
                "ja": "`alpha` のエイリアス（CSS 風命名）。"
              },
              "anchorUrl": "#attr-opacity"
            },
            {
              "id": "overview_touchDisabledState",
              "name": "touchDisabledState",
              "type": "string",
              "summary": {
                "en": "Disables touch when the component is in a specified state (e.g., while an animation runs).",
                "ja": "指定状態（例: アニメーション中）のときタッチを無効化。"
              },
              "anchorUrl": "#attr-touchDisabledState"
            },
            {
              "id": "overview_touchEnabledViewIds",
              "name": "touchEnabledViewIds",
              "type": "array",
              "summary": {
                "en": "Array of sibling IDs that remain tappable even when this view blocks touches (e.g., for a dimming…",
                "ja": "この View がタッチを遮っている状況でも、タップを通す兄弟 View の ID 配列（例: 特定ボタンをブロックしない減光オーバーレイ）。"
              },
              "anchorUrl": "#attr-touchEnabledViewIds"
            },
            {
              "id": "overview_userInteractionEnabled",
              "name": "userInteractionEnabled",
              "type": "boolean | binding",
              "summary": {
                "en": "iOS-style alias for `canTap`.",
                "ja": "`canTap` の iOS 風エイリアス。"
              },
              "anchorUrl": "#attr-userInteractionEnabled"
            },
            {
              "id": "overview_visibility",
              "name": "visibility",
              "type": "string | binding",
              "summary": {
                "en": "`visible` / `invisible` / `gone`. `invisible` preserves space; `gone` removes from layout entirely.",
                "ja": "`visible` / `invisible` / `gone`。`invisible` はスペースを確保して非表示、`gone` はレイアウトから完全除外。"
              },
              "anchorUrl": "#attr-visibility"
            }
          ]
        }
      }
    ]
  },
