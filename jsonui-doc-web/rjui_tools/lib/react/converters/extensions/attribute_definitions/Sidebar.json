{
  "Sidebar": {
    "items": {
      "type": ["array", "binding"],
      "description": "Ordered SidebarSection list. Usually @{bindingName} from a ViewModel."
    },
    "activeUrl": {
      "type": ["string", "binding"],
      "description": "Current route; drives the aria-current='page' decoration."
    },
    "collapsedIds": {
      "type": ["array", "binding"],
      "description": "Section ids that start collapsed."
    },
    "mobileOpen": {
      "type": ["boolean", "binding"],
      "description": "Mobile drawer open flag."
    },
    "onToggleSection": {
      "type": ["binding"],
      "description": "Event: (id: String) -> Void."
    },
    "onLinkTap": {
      "type": ["binding"],
      "description": "Optional event: (url: String) -> Void."
    }
  }
}
